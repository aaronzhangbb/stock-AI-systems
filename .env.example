# ========================================
# A股量化交易辅助系统 - 环境变量配置模板
# ========================================
# 使用方法: 复制此文件为 .env，按需修改参数值
# 优先级: .env > config.py 默认值
# 注意: .env 不提交 Git，每台机器独立维护

# ==================== 运行实例标识 ====================
# 用于区分不同机器的运行身份（可选）
INSTANCE_NAME=default

# ==================== 数据目录 ====================
# 所有数据库、缓存、模型、日志的根目录
# 不同机器可以指向不同目录实现状态隔离
# DATA_ROOT=data

# ==================== 邮件通知 ====================
EMAIL_ENABLE=true
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=360928477@qq.com
SMTP_PASSWORD=your_qq_smtp_auth_code
EMAIL_TO=360928477@qq.com

# ==================== 微信推送（PushPlus） ====================
# 从 https://www.pushplus.plus/ 扫码登录获取 Token
PUSHPLUS_TOKEN=

# ==================== 大模型 API ====================
BAILIAN_API_KEY=

# ==================== AI 自动交易参数 ====================
# AUTO_SCORE_THRESHOLD=75    # 自动买入最低AI评分
# AUTO_MAX_POSITIONS=50      # 最大同时持仓数
# AUTO_SELL_URGENCY=1        # 卖出紧急度 (1=建议+立即, 2=仅立即)
# AUTO_USE_KELLY_SIZE=true   # 是否使用Kelly仓位
AUTO_ENABLED=true             # 自动交易总开关
# AI_SELL_SCORE_DROP=15      # AI评分衰减卖出确认阈值

# ==================== 性能参数（机器差异化核心配置） ====================
# SCAN_LIMIT=0               # 扫描股票上限, 0=全量, 低配机建议设为 500
# ENABLE_HEAVY_MODEL=true    # 是否启用重模型(Transformer等), 低配机建议 false
# HISTORY_DAYS=365           # 历史数据拉取天数

# ==================== 盘中狙击 ====================
# SNIPER_ENABLED=false             # 狙击引擎开关
# SNIPER_INTERVAL_SECONDS=30       # 检查间隔(秒)
# SNIPER_BUY_ENABLED=true          # 是否执行买入
# SNIPER_SELL_ENABLED=true         # 是否执行卖出

# ==================== 模拟账户 ====================
# INITIAL_CAPITAL=1000000    # 初始资金(元)
